// FlatBuffers Schema for Triage Session Protocol
namespace triage.generated;

enum AttachMode : byte {
    Observer = 0,
    InteractiveController = 1,
    AgentController = 2
}

enum InputControllerKind : byte {
    Interactive = 0,
    Agent = 1
}

enum LeaseChangeAction : byte {
    Acquired = 0,
    Released = 1,
    TakenOver = 2
}

struct SessionSize {
    rows: uint32;
    cols: uint32;
    pixel_width: uint32;
    pixel_height: uint32;
    dpi: uint32;
}

struct TerminalCursor {
    row: uint32;
    col: uint32;
    visible: bool;
}

struct TerminalColor {
    red: ubyte;
    green: ubyte;
    blue: ubyte;
}

struct TerminalStyle {
    foreground: TerminalColor;
    has_foreground: bool;
    background: TerminalColor;
    has_background: bool;
    bold: bool;
    dim: bool;
    italic: bool;
    underline: bool;
    reverse: bool;
}

table StyledSpan {
    text: string;
    style: TerminalStyle;
}

table StyledRow {
    spans: [StyledSpan];
}

table SessionContext {
    repository_root: string;
    worktree_root: string;
    branch: string;
}

table SessionSnapshot {
    output_seq: uint64;
    bytes_logged: uint64;
    size: SessionSize;
    visible_rows: [string];
    styled_rows_start: uint32;
    styled_rows: [StyledRow];
    cursor: TerminalCursor;
    current_working_directory: string;
    context: SessionContext;
    bracketed_paste_enabled: bool;
    exited: bool;
    // Raw (untranslated) PTY output tail for client-side re-emulation — the
    // single source of truth for history. Byte-identical to the live Output
    // stream. Empty from old hosts. raw_output_start is the byte offset of the
    // first byte within the session's full output log (bytes_logged is the end).
    raw_output: [ubyte];
    raw_output_start: uint64;
    // Local-LLM one-line description of what this session is doing, if generated.
    // Empty/absent when summarization is disabled or not yet produced.
    snippet: string;
    // Local-LLM longer-form summary (a few sentences) for the side-rail hover
    // popover and future session search. Empty/absent when not yet produced.
    snippet_detail: string;
}

table CompletedSession {
    output_seq: uint64;
    bytes_logged: uint64;
    visible_rows: [string];
}

table InputLeaseHolder {
    client_id: string;
    kind: InputControllerKind;
}

table InputLeaseState {
    holder: InputLeaseHolder;
    generation: uint64;
}

table LeaseChange {
    generation: uint64;
    previous: InputLeaseHolder;
    current: InputLeaseHolder;
    action: LeaseChangeAction;
}

table AttachSessionResponse {
    snapshot: SessionSnapshot;
    lease: InputLeaseState;
}

table StyledRowsResponse {
    output_seq: uint64;
    start: uint32;
    rows: [StyledRow];
}

// --- CLIENT REQUESTS ---

table HelloRequest {
    client_id: string;
    token: string;
}

table PairRequest {
    code: string;
    client_id: string;
}

table PairingChallengeRequest {
    client_id: string;
}

table ListSessionsRequest {}

table StartSessionRequestTable {
    command: string;
    args: [string];
    cwd: string;
    size: SessionSize;
}

table AttachSessionRequestTable {
    session_id: string;
    client_id: string;
    mode: AttachMode;
}

table SubscribeSessionEventsRequestTable {
    session_id: string;
    after_event_seq: uint64;
}

table AcquireInputLeaseRequest {
    session_id: string;
    client_id: string;
    kind: InputControllerKind;
}

table ReleaseInputLeaseRequest {
    session_id: string;
    client_id: string;
}

table WriteInputRequestTable {
    session_id: string;
    client_id: string;
    bytes: [ubyte]; // HOT PATH: Raw input stream bytes
}

table ResizeSessionRequestTable {
    session_id: string;
    size: SessionSize;
}

table RestoreSessionRequestTable {
    session_id: string;
    size: SessionSize;
}

table SnapshotSessionRequest {
    session_id: string;
}

table StyledRowsRequestTable {
    session_id: string;
    start: uint32;
    end: uint32;
}

table ShutdownSessionRequest {
    session_id: string;
}

table ListSessionSnippetsRequest {}

union ClientRequestPayload {
    HelloRequest,
    PairRequest,
    ListSessionsRequest,
    StartSessionRequestTable,
    AttachSessionRequestTable,
    SubscribeSessionEventsRequestTable,
    AcquireInputLeaseRequest,
    ReleaseInputLeaseRequest,
    WriteInputRequestTable,
    ResizeSessionRequestTable,
    RestoreSessionRequestTable,
    SnapshotSessionRequest,
    StyledRowsRequestTable,
    ShutdownSessionRequest,
    PairingChallengeRequest,
    ListSessionSnippetsRequest
}

table ClientMessage {
    id: string;
    payload: ClientRequestPayload;
}

// --- SERVER MESSAGES ---

table UnitResult {}

table HelloResult {
    protocol_version: string;
    authenticated: bool;
    // Self-update fields (appended for forward/backward compatibility): the
    // running daemon version, whether a newer stable release exists, and the
    // newest tag seen (normalized, no leading `v`; empty until the first check).
    server_version: string;
    update_available: bool;
    latest_version: string;
}

table PairedResult {
    token: string;
}

table PairingChallengeResult {
    device_code: string;
    expires_at: uint64;
}

table SessionIdsResult {
    session_ids: [string];
}

table SessionIdResult {
    session_id: string;
}

table AttachSessionResult {
    response: AttachSessionResponse;
}

table SubscribedResult {
    subscription_id: string;
}

table LeaseChangeResult {
    change: LeaseChange;
}

table SessionSnapshotResult {
    snapshot: SessionSnapshot;
}

table StyledRowsResult {
    response: StyledRowsResponse;
}

table CompletedSessionResult {
    completed: CompletedSession;
}

table SessionSnippetEntry {
    session_id: string;
    snippet: string;
    detail: string;
}

table SessionSnippetsResult {
    entries: [SessionSnippetEntry];
}

union ServerResultPayload {
    UnitResult,
    HelloResult,
    PairedResult,
    SessionIdsResult,
    SessionIdResult,
    AttachSessionResult,
    SubscribedResult,
    LeaseChangeResult,
    SessionSnapshotResult,
    StyledRowsResult,
    CompletedSessionResult,
    PairingChallengeResult,
    SessionSnippetsResult
}

table ResponsePayload {
    id: string;
    result: ServerResultPayload;
}

table ErrorPayload {
    id: string;
    code: string;
    message: string;
}

table ResyncRequiredEvent {
    session_id: string;
    latest_event_seq: uint64;
    snapshot: SessionSnapshot;
}

table OutputEvent {
    session_id: string;
    output_seq: uint64;
    bytes: [ubyte]; // HOT PATH: Dynamic binary terminal stream bytes
}

table SnapshotEvent {
    session_id: string;
    snapshot: SessionSnapshot;
}

table LeaseChangedEvent {
    session_id: string;
    change: LeaseChange;
}

table ExitedEvent {
    session_id: string;
    completed: CompletedSession;
}

union SessionEventPayload {
    ResyncRequiredEvent,
    OutputEvent,
    SnapshotEvent,
    LeaseChangedEvent,
    ExitedEvent
}

table EventPayload {
    subscription_id: string;
    event_seq: uint64;
    event: SessionEventPayload;
}

table SubscriptionClosedPayload {
    subscription_id: string;
}

// Connection-wide push (not tied to a session subscription): a session's
// snippet was (re)generated. Broadcast to every connected client so the side
// rail can update sessions the client hasn't attached to.
table SessionSnippetUpdatedPayload {
    session_id: string;
    snippet: string;
    output_seq: uint64;
    detail: string;
}

// Connection-wide push (not tied to a session subscription): a session's git
// context (or current working directory) changed. Broadcast to every connected
// client so the side rail stays fresh as the session's shell `cd`s, without
// re-attaching. `current_working_directory` is set whenever known, even when the
// session is not inside a git repo; the repo/worktree/branch fields are unset in
// that case so the rail can fall back to showing the cwd.
table SessionContextUpdatedPayload {
    session_id: string;
    current_working_directory: string;
    repository_root: string;
    worktree_root: string;
    branch: string;
}

// Connection-wide push (not tied to a session subscription): the daemon's
// background update check observed a newer stable release. Broadcast once on the
// transition; the same information also rides every HelloResult, so a missed
// push is recovered on the next handshake.
table UpdateAvailablePayload {
    current_version: string;
    latest_version: string;
}

union ServerMessagePayload {
    ResponsePayload,
    ErrorPayload,
    EventPayload,
    SubscriptionClosedPayload,
    SessionSnippetUpdatedPayload,
    SessionContextUpdatedPayload,
    UpdateAvailablePayload
}

table ServerMessage {
    payload: ServerMessagePayload;
}

root_type ServerMessage;
